-- ==================== Tracer ====================
local function updateTracer()
    for _,p in pairs(tracerParts) do pcall(function() p:Destroy() end) end
    tracerParts = {}
    if not S.Tracer then return end
    local target = ass or xer
    if not target or not target.Character then return end
    local char = plr.Character or plr.CharacterAdded:Wait()
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local tHrp = target.Character:FindFirstChild("HumanoidRootPart")
    if hrp and tHrp then
        local line = Instance.new("Part")
        line.Size = Vector3.new(0.2,0.2,(hrp.Position - tHrp.Position).Magnitude)
        line.CFrame = CFrame.lookAt(hrp.Position, tHrp.Position) * CFrame.new(0,0,-line.Size.Z/2)
        line.BrickColor = BrickColor.new("Bright red")
        line.Material = Enum.Material.Neon
        line.Anchored = true
        line.CanCollide = false
        line.Parent = WS
        table.insert(tracerParts, line)
        task.spawn(function()
            while S.Tracer and line and line.Parent do
                task.wait(0.2)
                local newChar = plr.Character or plr.CharacterAdded:Wait()
                if newChar and target.Character then
                    local newHrp = newChar:FindFirstChild("HumanoidRootPart")
                    local newTHrp = target.Character:FindFirstChild("HumanoidRootPart")
                    if newHrp and newTHrp then
                        local newDist = (newHrp.Position - newTHrp.Position).Magnitude
                        line.Size = Vector3.new(0.2,0.2,newDist)
                        line.CFrame = CFrame.lookAt(newHrp.Position, newTHrp.Position) * CFrame.new(0,0,-newDist/2)
                    else
                        break
                    end
                else
                    break
                end
            end
            pcall(function() line:Destroy() end)
        end)
    end
end

task.spawn(function()
    while true do
        task.wait(0.5)
        if S.Tracer then pcall(updateTracer) else for _,p in pairs(tracerParts) do pcall(function() p:Destroy() end) end end
    end
end)

