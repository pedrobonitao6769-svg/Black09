-- TP Tool (CORRIGIDO: mouse seguro para mobile)
local function createTPTool()
    if tpToolPart then pcall(function() tpToolPart:Destroy() end) end
    tpToolPart = Instance.new("Part")
    tpToolPart.Name = "TP_TOOL"
    tpToolPart.Size = Vector3.new(2,2,2)
    tpToolPart.BrickColor = BrickColor.new("Bright violet")
    tpToolPart.Material = Enum.Material.Neon
    tpToolPart.Anchored = false
    tpToolPart.CanCollide = false
    tpToolPart.Parent = WS
    local billboard = Instance.new("BillboardGui")
    billboard.Name = "TP_GUI"
    billboard.Size = UDim2.new(0,100,0,50)
    billboard.StudsOffset = Vector3.new(0,3,0)
    billboard.AlwaysOnTop = true
    billboard.Parent = tpToolPart
    local text = Instance.new("TextLabel")
    text.Size = UDim2.new(1,0,1,0)
    text.BackgroundTransparency = 1
    text.Text = "📍 TP TOOL\n(Clique para teleportar)"
    text.TextColor3 = Color3.new(1,1,1)
    text.TextScaled = true
    text.Font = Enum.Font.GothamBold
    text.Parent = billboard
    local click = Instance.new("ClickDetector")
    click.Parent = tpToolPart
    click.MaxActivationDistance = 50
    click.MouseClick:Connect(function(player)
        if player == plr then
            local char = plr.Character or plr.CharacterAdded:Wait()
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart.CFrame = tpToolPart.CFrame * CFrame.new(0,3,0)
                n("📍 TP", "Teleportado!", 2)
            end
        end
    end)
    task.spawn(function()
        while S.TPTool and tpToolPart and tpToolPart.Parent do
            task.wait(0.05)
            pcall(function()
                local mouse = pcall(function() return plr:GetMouse() end) and plr:GetMouse()
                if not mouse then
                    local ray = cam:ScreenPointToRay(cam.ViewportSize.X/2, cam.ViewportSize.Y/2)
                    local params = RaycastParams.new()
                    params.FilterType = Enum.RaycastFilterType.Blacklist
                    local char = plr.Character
                    if char then params.FilterDescendantsInstances = {char} end
                    local hit = WS:Raycast(ray.Origin, ray.Direction * 100, params)
                    if hit then tpToolPart.CFrame = CFrame.new(hit.Position + Vector3.new(0,1,0))
                    else tpToolPart.CFrame = CFrame.new(ray.Origin + ray.Direction * 20) end
                else
                    local ray = cam:ScreenPointToRay(mouse.X, mouse.Y)
                    local params = RaycastParams.new()
                    params.FilterType = Enum.RaycastFilterType.Blacklist
                    local char = plr.Character
                    if char then params.FilterDescendantsInstances = {char} end
                    local hit = WS:Raycast(ray.Origin, ray.Direction * 100, params)
                    if hit then tpToolPart.CFrame = CFrame.new(hit.Position + Vector3.new(0,1,0))
                    else tpToolPart.CFrame = CFrame.new(ray.Origin + ray.Direction * 20) end
                end
            end)
        end
    end)
end

