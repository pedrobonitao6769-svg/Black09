-- Identificar papéis (CORRIGIDO: Character seguro)
local function roles()
    local a = nil
    local x = nil
    for _,p in pairs(P:GetPlayers()) do
        if p ~= plr then
            local char = p.Character or p.CharacterAdded:Wait()
            if char then
                if char:FindFirstChild("Knife") or (p.Backpack and p.Backpack:FindFirstChild("Knife")) then
                    a = p
                elseif char:FindFirstChild("Gun") or (p.Backpack and p.Backpack:FindFirstChild("Gun")) then
                    x = p
                end
            end
        end
    end
    ass = a or ass
    xer = x or xer
    return ass, xer
end

